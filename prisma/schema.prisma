// Carnet d'entretien auto — schéma de la base de données
// Suivi des véhicules : entretiens, réparations, carburant, kilométrage,
// documents administratifs (assurance, contrôle technique…) et rappels.
//
// Dev  : SQLite (provider = "sqlite", DATABASE_URL="file:./dev.db")
// Prod : pour PostgreSQL, remplacez provider par "postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Comptes & accès ---

model User {
  id           String       @id @default(cuid())
  // E-mail facultatif : un compte peut être créé par l'admin sans e-mail ;
  // l'utilisateur le renseigne en activant son accès via une invitation.
  email        String?      @unique
  passwordHash String
  name         String
  firstName    String? // prénom (champ profil facultatif)
  lastName     String? // nom (champ profil facultatif)
  phone        String? // téléphone (champ profil facultatif)
  isAdmin      Boolean      @default(false) // peut créer/gérer les comptes
  // Compte actif : un compte créé par l'admin sans accès est `false` et passe
  // à `true` lorsque la personne accepte son invitation (choisit un mot de passe).
  activated    Boolean      @default(true)
  createdAt    DateTime     @default(now())
  memberships  Membership[]
  invitesSent  Invite[]     @relation("InviteCreatedBy")
  invitesFor   Invite[]     @relation("InviteTarget")
}

// Un garage regroupe les personnes qui suivent un ou plusieurs véhicules :
// propriétaires, conducteurs de la famille, etc.
model Garage {
  id          String           @id @default(cuid())
  name        String
  address     String? // coordonnées facultatives
  phone       String?
  createdAt   DateTime         @default(now())
  memberships Membership[]
  vehicles    Vehicle[]
  invites     Invite[]
  services    ServiceContact[]
  sharedVehicles VehicleShare[]
}

enum Role {
  OWNER  // accès complet, gestion des membres (≈ "OWNER")
  DRIVER // conducteur / famille : vision d'ensemble + saisie, hors finances (≈ "EMPLOYEE")
  VIEWER // lecture seule minimale, ne voit que l'essentiel (≈ "MEMBER")
}

model Membership {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  garageId  String
  role      Role     @default(DRIVER)
  createdAt DateTime @default(now())

  @@unique([userId, garageId])
}

// Invitation créée par un administrateur : l'utilisateur choisit lui-même son
// mot de passe via le lien (aucun mot de passe n'est défini par l'admin).
// Si `userId` est défini, l'invitation ACTIVE ce compte existant au lieu d'en
// créer un nouveau.
model Invite {
  id          String    @id @default(cuid())
  token       String    @unique
  email       String?
  name        String
  garage      Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  garageId    String
  role        Role      @default(DRIVER)
  createdBy   User?     @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  // Compte existant à activer (créé par l'admin sans accès).
  user        User?     @relation("InviteTarget", fields: [userId], references: [id], onDelete: Cascade)
  userId      String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?
}

// Surcharge en base des droits par défaut d'un rôle. `perms` = JSON (liste des
// clés de droits accordées, voir src/lib/perms.ts). Si une ligne existe pour un
// rôle, elle remplace les droits par défaut ; sinon ROLE_DEFAULTS s'applique.
model RolePerms {
  role      String   @id // "OWNER" | "DRIVER" | "VIEWER"
  perms     String   @default("[]")
  updatedAt DateTime @updatedAt
}

// --- Véhicule ---

enum FuelType {
  GASOLINE // Essence
  DIESEL
  ELECTRIC // Électrique
  HYBRID   // Hybride
  LPG      // GPL
  OTHER
}

enum VehicleCategory {
  CAR          // Voiture
  MOTORCYCLE   // Moto / scooter
  VAN          // Utilitaire / fourgon
  TRUCK        // Camion / poids lourd
  TRACTOR      // Tracteur
  AGRICULTURAL // Engin agricole
  OTHER
}

// Unité d'usage : kilomètres (route) ou heures moteur (engins agricoles…).
enum UsageUnit {
  KM
  HOURS
}

model Vehicle {
  id            String          @id @default(cuid())
  // Garage propriétaire. Le véhicule peut aussi être partagé avec d'autres
  // garages via VehicleShare (relation plusieurs-à-plusieurs).
  garage        Garage          @relation(fields: [garageId], references: [id], onDelete: Cascade)
  garageId      String
  name          String // surnom / désignation libre (ex. "La Clio")
  category      VehicleCategory @default(CAR)
  usageUnit     UsageUnit       @default(KM) // km (route) ou heures moteur
  make          String? // marque (ex. Renault)
  model         String? // modèle (ex. Clio IV)
  year          Int? // année de mise en circulation
  plate         String? // immatriculation
  vin           String? // numéro de série (VIN)
  fuelType      FuelType        @default(GASOLINE)
  tankCapacity  Float? // capacité du réservoir (L), pour info
  initialMileage Int? // compteur (km ou h) à l'achat / création du profil
  notes         String?

  // --- Données issues de la carte grise (certificat d'immatriculation) ---
  // Repères normalisés entre parenthèses. Tous facultatifs ; alimentés depuis
  // la photo de carte grise (analyse IA, après validation champ par champ).
  vehicleType         String? // D.2 — type, variante, version
  firstRegistrationDate DateTime? // B — date de 1re mise en circulation
  registrationDate    DateTime? // I — date du certificat
  displacementCc      Int? // P.1 — cylindrée (cm³)
  powerKw             Int? // P.2 — puissance nette maximale (kW)
  fiscalPower         Int? // P.6 — puissance administrative (CV fiscaux)
  seats               Int? // S.1 — nombre de places assises
  co2                 Int? // V.7 — émissions de CO2 (g/km)
  emissionClass       String? // V.9 — classe environnementale (norme Euro)
  massInService       Int? // G — masse en service / poids à vide (kg)
  maxLadenMass        Int? // F.2 — masse en charge max admissible en service (kg)
  categoryEu          String? // J — catégorie du véhicule (CE)
  nationalType        String? // J.1 — genre national (VP, CTTE…)
  bodyworkCe          String? // J.2 — carrosserie (CE)
  bodyworkNational    String? // J.3 — carrosserie (désignation nationale)
  typeApprovalNumber  String? // K — numéro de réception par type
  holderName          String? // C.1 — nom du titulaire
  holderAddress       String? // C.3 — adresse du titulaire

  // Partage public (QR) : page en lecture seule de l'historique d'entretien,
  // accessible sans connexion via le jeton. Désactivable / régénérable.
  publicToken   String?         @unique
  publicEnabled Boolean         @default(false)

  createdAt     DateTime        @default(now())

  maintenances  Maintenance[]
  repairs       Repair[]
  fuelEntries   FuelEntry[]
  mileageEntries MileageEntry[]
  documents     Document[]
  reminders     Reminder[]
  shares        VehicleShare[]
  registration  VehicleRegistration?
  // Plan d'entretien : plusieurs pages/photos possibles + intervalles agrégés
  // (JSON) extraits par IA depuis l'ensemble des pages.
  servicePlanIntervals String              @default("[]")
  servicePlanDocs      VehicleServicePlanDoc[]
  manual        VehicleManual?
  diagnostics   DiagnosticReport[]
}

// Relevé de diagnostic OBD2 (lecture ELM327 via Web Bluetooth) : codes défaut
// lus, tension, VIN, horodatage. Journalise l'historique des diagnostics.
model DiagnosticReport {
  id          String   @id @default(cuid())
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId   String
  performedAt DateTime @default(now())
  mileage     Int? // compteur au moment de la lecture
  codes       String   @default("[]") // JSON : [{ code, description, pending }]
  voltage     Float? // tension batterie mesurée (ATRV), en volts
  vin         String? // VIN lu sur le port OBD (mode 09)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([vehicleId, performedAt])
}

// Une page/photo du programme d'entretien du carnet constructeur. Plusieurs par
// véhicule (le plan tient souvent sur plusieurs pages). L'IA les analyse toutes
// ensemble pour produire `Vehicle.servicePlanIntervals`.
model VehicleServicePlanDoc {
  id        String   @id @default(cuid())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId String
  data      Bytes
  mimeType  String
  fileName  String?
  createdAt DateTime @default(now())

  @@index([vehicleId, createdAt])
}

// Manuel / notice d'utilisation du véhicule : soit un fichier (PDF) stocké en
// base, soit un lien externe.
model VehicleManual {
  id        String   @id @default(cuid())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId String   @unique
  data      Bytes? // fichier (PDF) si uploadé
  mimeType  String?
  fileName  String?
  url       String? // lien externe si renseigné à la place du fichier
  title     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Photo de la carte grise, réservée au propriétaire du véhicule (droit
// `registrationView`). Stockée en base (Bytes) — pas de volume disque à gérer.
// Une seule par véhicule (remplacée à chaque nouvel envoi).
model VehicleRegistration {
  id        String   @id @default(cuid())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId String   @unique
  data      Bytes // contenu de l'image
  mimeType  String // ex. image/jpeg
  fileName  String?
  // Dernier résultat d'analyse IA (JSON des champs détectés) + horodatage,
  // conservé pour proposer un aperçu/validation et garder une trace brute.
  extracted   String?
  extractedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Partage d'un véhicule avec un garage supplémentaire (en plus du propriétaire).
model VehicleShare {
  id        String   @id @default(cuid())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId String
  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  garageId  String
  createdAt DateTime @default(now())

  @@unique([vehicleId, garageId])
}

// --- Entretiens ---

enum MaintenanceType {
  VIDANGE                // Vidange huile moteur
  FILTRE_HUILE           // Filtre à huile
  FILTRE_AIR             // Filtre à air
  FILTRE_HABITACLE       // Filtre habitacle / pollen
  FILTRE_CARBURANT       // Filtre à carburant
  FREINS                 // Plaquettes / disques de frein
  LIQUIDE_DE_FREIN       // Purge du liquide de frein
  PNEUS                  // Pneumatiques
  COURROIE_DISTRIBUTION  // Courroie de distribution
  COURROIE_ACCESSOIRE    // Courroie d'accessoires
  BOUGIES                // Bougies d'allumage / préchauffage
  BATTERIE               // Batterie
  AMORTISSEURS           // Amortisseurs / suspension
  ECHAPPEMENT            // Échappement
  CLIMATISATION          // Recharge / entretien clim
  LIQUIDE_REFROIDISSEMENT// Liquide de refroidissement
  ESSUIE_GLACE           // Balais d'essuie-glace
  REVISION               // Révision générale (constructeur)
  LAVAGE_EXTERIEUR       // Lavage extérieur (carrosserie)
  LAVAGE_INTERIEUR       // Lavage / nettoyage intérieur
  LAVAGE_SIEGES          // Nettoyage des sièges
  NETTOYAGE_JANTES       // Nettoyage des jantes
  POLISSAGE              // Polissage / lustrage carrosserie
  DESINFECTION           // Désinfection habitacle
  AUTRE
}

model Maintenance {
  id          String          @id @default(cuid())
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId   String
  type        MaintenanceType @default(REVISION) // type principal (1er coché)
  types       String? // tous les types cochés, séparés par des virgules (multi-sélection)
  title       String? // précision libre (ex. "Vidange + filtre")
  performedAt DateTime
  mileage     Int? // kilométrage au moment de l'entretien
  cost        Float? // coût TTC
  serviceName String? // garage / lieu (auto-ajouté au catalogue)
  notes       String?
  // Prochaine échéance facultative (alimente l'aperçu et les rappels) :
  nextDueDate    DateTime?
  nextDueMileage Int?
  createdAt   DateTime        @default(now())
  attachments MaintenanceAttachment[]

  @@index([vehicleId, performedAt])
}

// Pièce jointe d'un entretien : facture, photo, PDF du contrôle technique…
// Plusieurs par entretien. Stockée en base (Bytes) — pas de volume disque.
model MaintenanceAttachment {
  id            String      @id @default(cuid())
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  maintenanceId String
  data          Bytes // contenu du fichier
  mimeType      String // ex. image/jpeg, application/pdf
  fileName      String?
  createdAt     DateTime    @default(now())

  @@index([maintenanceId])
}

// --- Réparations / pannes ---

model Repair {
  id          String   @id @default(cuid())
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId   String
  title       String // description courte (ex. "Remplacement alternateur")
  performedAt DateTime
  mileage     Int?
  cost        Float?
  serviceName String?
  underWarranty Boolean @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([vehicleId, performedAt])
}

// --- Carburant ---

model FuelEntry {
  id          String   @id @default(cuid())
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId   String
  filledAt    DateTime
  mileage     Int? // kilométrage au plein (pour calcul de consommation)
  liters      Float
  pricePerLiter Float?
  totalCost   Float?
  fullTank    Boolean  @default(true) // plein complet (requis pour la conso)
  station     String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([vehicleId, filledAt])
}

// --- Relevés kilométriques (pour le graphique d'évolution) ---

model MileageEntry {
  id         String   @id @default(cuid())
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId  String
  readAt     DateTime
  mileage    Int
  notes      String?
  createdAt  DateTime @default(now())

  @@index([vehicleId, readAt])
}

// --- Documents administratifs (assurance, contrôle technique…) ---

enum DocumentType {
  ASSURANCE
  CONTROLE_TECHNIQUE
  CARTE_GRISE
  VIGNETTE_CRITAIR
  GARANTIE
  AUTRE
}

model Document {
  id        String       @id @default(cuid())
  vehicle   Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId String
  type      DocumentType @default(ASSURANCE)
  label     String? // précision (ex. "Tous risques — MAIF")
  provider  String? // organisme / centre
  issuedAt  DateTime?
  expiresAt DateTime? // échéance (alimente rappels et export .ics)
  cost      Float?
  notes     String?
  createdAt DateTime     @default(now())

  @@index([vehicleId, expiresAt])
}

// --- Rappels ---

enum ReminderKind {
  MAINTENANCE
  CONTROLE_TECHNIQUE
  ASSURANCE
  DOCUMENT
  OTHER
}

model Reminder {
  id         String       @id @default(cuid())
  vehicle    Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleId  String
  kind       ReminderKind @default(MAINTENANCE)
  label      String
  dueDate    DateTime? // échéance par date
  dueMileage Int? // échéance par kilométrage
  done       Boolean      @default(false)
  notes      String?
  createdAt  DateTime     @default(now())

  @@index([vehicleId, dueDate])
}

// --- Catalogue de garages / prestataires (par garage utilisateur) ---

model ServiceContact {
  id         String   @id @default(cuid())
  garage     Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  garageId   String
  name       String
  brand      String? // enseigne (ex. Norauto)
  address    String?
  postalCode String?
  city       String?
  phone      String?
  notes      String?
  createdAt  DateTime @default(now())

  @@unique([garageId, name])
}
