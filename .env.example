# --- Base de données ---
# Développement local (SQLite, aucun serveur requis) :
DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL recommandé — Railway, Render, Neon, Supabase...) :
# DATABASE_URL="postgresql://user:password@host:5432/carnet?schema=public"
# Pensez alors à passer provider = "postgresql" dans prisma/schema.prisma

# --- Authentification ---
# Clé secrète pour signer les jetons de session (JWT).
# Générez-en une avec : openssl rand -base64 32
AUTH_SECRET="changez-moi-en-production-avec-une-cle-aleatoire-longue"

# --- Cookie de session ---
# Mettez à "true" UNIQUEMENT si l'app est servie en HTTPS (ex. derrière Caddy
# avec un nom de domaine). En HTTP simple (réseau local, VPN), laissez "false",
# sinon le cookie de session n'est jamais transmis et vous êtes déconnecté à
# chaque navigation.
COOKIE_SECURE="false"

# --- Analyse IA de la carte grise (optionnel) ---
# Permet de lire la photo de la carte grise pour pré-remplir le profil du
# véhicule (marque, modèle, immatriculation, VIN, année, carburant) via Claude.
# Sans cette clé, l'envoi et l'affichage de la photo fonctionnent, mais le
# bouton « Analyser avec l'IA » est désactivé.
# Obtenez une clé sur https://console.anthropic.com/
# ANTHROPIC_API_KEY="sk-ant-..."

# --- IA locale (optionnel : Ollama / LM Studio, compatible OpenAI) ---
# Si renseigné, TOUTES les fonctions IA (scans carte grise/facture/huile/CT,
# plan d'entretien, aide au diagnostic OBD, base de connaissances véhicule et
# procédure de réinitialisation) appellent votre IA locale au lieu de Claude.
# Repli automatique sur Claude si ces variables sont vides.
# NB : les 2 fonctions « base de connaissances » et « procédure de réinit »
# utilisent la RECHERCHE WEB de Claude quand c'est Claude qui répond (sources
# à l'appui). Avec une IA locale (sans accès web), la réponse provient des
# CONNAISSANCES du modèle : gratuit et hors-ligne, mais sans sources web et un
# peu moins précis sur les commandes constructeur exactes.
# PDF : l'IA locale ne lit que des images. Les PDF (carte grise, CT, factures)
# sont convertis en image via poppler — installez-le sur le serveur :
#   sudo apt install -y poppler-utils   (fournit la commande pdftoppm)
# Sans poppler, importez une PHOTO du document au lieu du PDF.
# LOCAL_AI_BASE_URL="http://192.168.1.50:11434/v1"   # Ollama (avec /v1)
# LOCAL_AI_MODEL="llama3.2-vision:11b"               # modèle VISION (scans photo)
# LOCAL_AI_TEXT_MODEL="qwen2.5:14b"                  # optionnel : modèle TEXTE (diag OBD)
# LOCAL_AI_API_KEY="ollama"                          # optionnel (Ollama l'ignore)

# --- Recherche véhicule par plaque (optionnel, payant) ---
# Le décodage par VIN fonctionne sans rien (API publique gratuite NHTSA).
# La recherche par PLAQUE nécessite un abonnement chez un fournisseur d'API SIV
# (ex. apiplaqueimmatriculation.com). Renseignez votre clé ci-dessous :
# PLATE_API_KEY="votre-token"
# Optionnel : URL du fournisseur ({plate} et {token} sont remplacés).
# Par défaut : apiplaqueimmatriculation.com
# PLATE_API_URL="https://api.apiplaqueimmatriculation.com/get?immatriculation={plate}&token={token}"

