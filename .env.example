# --- Base de données ---
# Développement local (SQLite, aucun serveur requis) :
DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL recommandé — Railway, Render, Neon, Supabase...) :
# DATABASE_URL="postgresql://user:password@host:5432/carnet?schema=public"
# Pensez alors à passer provider = "postgresql" dans prisma/schema.prisma

# --- Authentification ---
# Clé secrète pour signer les jetons de session (JWT).
# Générez-en une avec : openssl rand -base64 32
AUTH_SECRET="changez-moi-en-production-avec-une-cle-aleatoire-longue"

# --- Cookie de session ---
# Mettez à "true" UNIQUEMENT si l'app est servie en HTTPS (ex. derrière Caddy
# avec un nom de domaine). En HTTP simple (réseau local, VPN), laissez "false",
# sinon le cookie de session n'est jamais transmis et vous êtes déconnecté à
# chaque navigation.
COOKIE_SECURE="false"

# --- Recherche véhicule par plaque (optionnel, payant) ---
# Le décodage par VIN fonctionne sans rien (API publique gratuite NHTSA).
# La recherche par PLAQUE nécessite un abonnement chez un fournisseur d'API SIV
# (ex. apiplaqueimmatriculation.com). Renseignez votre clé ci-dessous :
# PLATE_API_KEY="votre-token"
# Optionnel : URL du fournisseur ({plate} et {token} sont remplacés).
# Par défaut : apiplaqueimmatriculation.com
# PLATE_API_URL="https://api.apiplaqueimmatriculation.com/get?immatriculation={plate}&token={token}"

